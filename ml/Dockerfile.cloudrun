# Reuse the already-built local BentoML image (deps installed) and bake trained models.
FROM nigeriaflooddashboard-bentoml:latest

WORKDIR /app
COPY service.py train.py ./

ENV BENTOML_HOME=/root/bentoml
COPY bentoml_store/ /root/bentoml/

ENV PORT=3000
EXPOSE 3000

CMD ["sh", "-c", "bentoml serve service:svc --host 0.0.0.0 --port ${PORT:-3000}"]
