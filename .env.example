# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────
POSTGRES_USER=flood
POSTGRES_PASSWORD=floodpass
POSTGRES_DB=flooddb

# ── MinIO (local object store) ────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── API ───────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Google Maps / Places (optional but recommended) ──
# Enable Places API (legacy Text Search / Nearby Search) in Google Cloud.
# Optional: Geocoding API (better reverse geocode) and Map Tiles API (Google basemap).
# GOOGLE_MAPS_API_KEY=your-server-restricted-key
# Used server-side for place search, reverse geocode, nearby settlements, and Google basemap styles.
# When unset, the API falls back to Nominatim / local OSM place data.
GOOGLE_MAPS_API_KEY=

# ── Google Earth Engine ───────────────────────
# Register a service account at https://console.cloud.google.com
# and enable the Earth Engine API for your project.
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY=./your-key-file.json

# ── ML quality gates (optional overrides) ─────
# AUC_GATE=0.80
# F1_GATE=0.60

# ── SMS Alerts — Africa's Talking (optional) ──
# AT_API_KEY=your-key-here
# AT_USERNAME=your-username
