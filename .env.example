# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────
POSTGRES_USER=flood
POSTGRES_PASSWORD=floodpass
POSTGRES_DB=flooddb

# ── MinIO (local object store) ────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── API ───────────────────────────────────────
JWT_SECRET=change-me-in-production
# Developer API free-tier limits + key hashing pepper
API_FREE_RPM=60
API_FREE_DAILY_QUOTA=10000
API_KEY_PEPPER=gfw-dev-pepper-change-me

# ── Google Maps / Places (optional — text search only) ──
# Create the key on project ggis-flood-watch (not nigeria-flood-dashboard).
# Enable only Places API (legacy) → Text Search. Do NOT enable Map Tiles or Nearby Search.
# Nearby settlements always use OSM / Nominatim.
# GOOGLE_MAPS_API_KEY=your-server-restricted-key
GOOGLE_MAPS_API_KEY=
ENABLE_GOOGLE_MAP_TILES=0
ENABLE_GOOGLE_NEARBY=0
# 1 = allow Places Text Search when GOOGLE_MAPS_API_KEY is set; 0 = Nominatim only
ENABLE_GOOGLE_PLACES=1

# ── Google Earth Engine (project ggis-flood-watch) ──
# 1) Enable Earth Engine API on ggis-flood-watch
# 2) Create a service account + JSON key
# 3) Register the SA at https://code.earthengine.google.com/register
GEE_SERVICE_ACCOUNT_EMAIL=your-sa@ggis-flood-watch.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY=./ggis-flood-watch-gee.json
# ── ML quality gates (optional overrides) ─────
# AUC_GATE=0.80
# F1_GATE=0.60

# ── SMS Alerts — Africa's Talking (optional) ──
# AT_API_KEY=your-key-here
# AT_USERNAME=your-username
